// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Operator {
  id          String   @id @default(cuid())
  username    String   @unique
  password    String
  role        String   @default("OPERATOR")
  isActive    Boolean  @default(true)
  permissions String   @default("[]")
  skills      String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  operations      Operation[]      @relation("OperationOperator")
  auditLogs       AuditLog[]
  scheduledReports ScheduledReport[]
  createdOperations Operation[] @relation("CreatedBy")
  assignedTasks    Task[]         @relation("TaskAssignee")

  @@map("operators")
}

model Operation {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   @default("PENETRATION_TEST")
  priority    String   @default("MEDIUM")
  status      String   @default("PLANNING")
  team        String   @default("[]")
  objectives  Objective[]
  tasks       Task[]
  deliverables Deliverable[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String
  creator     Operator @relation("CreatedBy", fields: [createdBy], references: [id])

  // Relations
  executiveReports ExecutiveReport[]
  technicalReports TechnicalReport[]
  timelineReports  TimelineReport[]
  reportPackages   ReportPackage[]
  exfilPlans       ExfilPlan[]
  intelligence     Intelligence[]
  operatorId       String?
  operator         Operator?  @relation("OperationOperator", fields: [operatorId], references: [id])

  @@map("operations")
}

model Objective {
  id          String @id @default(cuid())
  title       String
  description String
  completed   Boolean @default(false)
  operationId String
  operation   Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  @@map("objectives")
}

model Task {
  id            String   @id @default(cuid())
  title         String
  description   String
  status        String   @default("PENDING")
  priority      String   @default("MEDIUM")
  assignedTo    String   @default("[]")
  dependencies  String   @default("[]")
  estimatedDuration Int
  actualDuration Int?
  operationId   String
  operation     Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)
  assigneeId    String?
  assignee      Operator?  @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("tasks")
}

model Deliverable {
  id          String   @id @default(cuid())
  name        String
  type        String
  description String
  status      String   @default("PENDING")
  operationId String
  operation   Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("deliverables")
}

model AuditLog {
  id          String   @id @default(cuid())
  operatorId  String
  action      String
  resource    String
  resourceId  String?
  details     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  operator    Operator @relation(fields: [operatorId], references: [id])

  @@map("audit_logs")
}

model ExecutiveReport {
  id          String   @id @default(cuid())
  title       String
  operationId String
  generatedAt DateTime @default(now())
  period      Json
  summary     Json
  keyFindings Json
  riskAssessment Json
  recommendations Json
  nextSteps   Json
  appendix    Json
  operation   Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  @@map("executive_reports")
}

model TechnicalReport {
  id          String   @id @default(cuid())
  title       String
  operationId String
  generatedAt DateTime @default(now())
  methodology Json
  findings    Json
  vulnerabilities Json
  exploits    Json
  evidence    Json
  tools       Json
  conclusions Json
  operation   Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  @@map("technical_reports")
}

model TimelineReport {
  id          String   @id @default(cuid())
  title       String
  operationId String
  generatedAt DateTime @default(now())
  events      Json
  milestones  Json
  activities  Json
  communications Json
  decisions   Json
  operation   Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  @@map("timeline_reports")
}

model ReportPackage {
  id          String   @id @default(cuid())
  operationId String
  generatedAt DateTime @default(now())
  reports     Json
  evidence    Json
  metadata    Json
  operation   Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  @@map("report_packages")
}

model ScheduledReport {
  id          String   @id @default(cuid())
  operationId String
  reportType  String
  frequency   String
  schedule    String
  recipients  String   @default("[]")
  options     Json?
  isActive    Boolean  @default(true)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  operator    Operator @relation(fields: [createdBy], references: [id])

  @@map("scheduled_reports")
}

model ExfilPlan {
  id          String   @id @default(cuid())
  operationId String
  team        String   @default("[]")
  data        Json
  dataTypes   String   @default("[]")
  methods     Json
  status      String   @default("PLANNING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  operation   Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  @@map("exfil_plans")
}

model Intelligence {
  id          String   @id @default(cuid())
  type        String
  title       String
  content     String
  source      String
  confidence  Int
  relevance   Int
  tags        String   @default("[]")
  operationIds String   @default("[]")
  sharedAt    DateTime @default(now())
  operationId String?
  operation   Operation? @relation(fields: [operationId], references: [id])

  @@map("intelligence")
}

model TransportProtocol {
  id          String   @id @default(cuid())
  name        String   @unique
  type        String
  config      Json
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("transport_protocols")
}

model Payload {
  id          String   @id @default(cuid())
  name        String
  type        String
  loaderType  String
  config      Json
  obfuscated  Boolean  @default(false)
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("payloads")
}

model OSINTData {
  id          String   @id @default(cuid())
  type        String
  target      String
  data        Json
  source      String
  confidence  Int
  collectedAt DateTime @default(now())

  @@map("osint_data")
}

model NetworkMap {
  id          String   @id @default(cuid())
  target      String
  topology    Json
  services    Json
  dataFlows   Json
  scannedAt   DateTime @default(now())

  @@map("network_maps")
}

model LotLTool {
  id          String   @id @default(cuid())
  name        String
  binaryPath  String
  description String
  category    String
  risk        String
  createdAt   DateTime @default(now())

  @@map("lotl_tools")
}

model ForensicsAction {
  id          String   @id @default(cuid())
  type        String
  target      String
  parameters  Json
  status      String   @default("PENDING")
  executedAt  DateTime?
  createdAt   DateTime @default(now())

  @@map("forensics_actions")
}

model ThreatIntel {
  id          String   @id @default(cuid())
  source      String
  type        String
  indicator   String
  data        Json
  confidence  Int
  severity    String
  createdAt   DateTime @default(now())

  @@map("threat_intel")
}

model BehaviorPattern {
  id          String   @id @default(cuid())
  userId      String
  pattern     Json
  anomaly     Boolean  @default(false)
  confidence  Float
  detectedAt  DateTime @default(now())

  @@map("behavior_patterns")
}

// ---------------------------------------------------------------------------
// Models replacing Firebase Firestore collections & in-memory mock stores
// ---------------------------------------------------------------------------

model ClientUser {
  id          String    @id @default(cuid())
  displayName String
  authToken   String    @unique
  status      String    @default("active")
  quotaBytes  BigInt?
  usedBytes   BigInt    @default(0)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  notes       String?

  @@map("client_users")
}

model HysteriaNode {
  id              String    @id @default(cuid())
  name            String
  hostname        String
  region          String?
  listenAddr      String    @default(":443")
  status          String    @default("stopped")
  tags            String    @default("[]")
  provider        String?
  profileId       String?
  lastHeartbeatAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("nodes")
}

model HysteriaServerConfig {
  id                  String   @id @default("current")
  listen              String   @default(":443")
  tls                 Json
  obfs                Json?
  bandwidth           Json?
  masquerade          Json?
  trafficStats        Json
  authBackendUrl      String
  authBackendInsecure Boolean  @default(false)
  updatedAt           DateTime @updatedAt

  @@map("server_configs")
}

model UsageRecord {
  id         String   @id @default(cuid())
  userId     String
  nodeId     String
  tx         Int
  rx         Int
  capturedAt DateTime @default(now())

  @@index([userId, capturedAt(sort: Desc)])
  @@map("usage_records")
}

model Profile {
  id          String   @id @default(cuid())
  name        String
  type        String
  description String   @default("")
  nodeIds     String   @default("[]")
  config      Json     @default("{}")
  tags        String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("profiles")
}

model AiConversation {
  id        String       @id @default(cuid())
  title     String       @default("New conversation")
  createdBy String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  messages  AiMessage[]

  @@index([createdBy, updatedAt(sort: Desc)])
  @@map("ai_conversations")
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String?
  toolCalls      Json?
  toolResult     Json?
  sortOrder      Int
  timestamp      DateTime       @default(now())

  @@index([conversationId, sortOrder])
  @@map("ai_messages")
}

model AgentTask {
  id           String      @id @default(cuid())
  status       String      @default("queued")
  prompt       String
  model        String
  allowedTools String      @default("[]")
  maxSteps     Int
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  finishedAt   DateTime?
  createdBy    String
  result       String?
  error        String?
  stepCount    Int         @default(0)
  steps        AgentStep[]

  @@map("agent_tasks")
}

model AgentStep {
  id        String    @id @default(cuid())
  taskId    String
  task      AgentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  index     Int
  kind      String
  at        DateTime  @default(now())
  content   String
  tool      String?
  arguments Json?
  result    Json?

  @@unique([taskId, index])
  @@map("agent_steps")
}

model OsintTask {
  id          String   @id @default(cuid())
  type        String   // domain, email, social, darkweb, threatintel
  target      String
  status      String   @default("pending") // pending, running, completed, failed
  results     Json?
  error       String?
  createdBy   String
  createdAt   DateTime @default(now())
  completedAt DateTime?
  metadata    Json?

  @@map("osint_tasks")
}

model WorkflowSession {
  id              String   @id @default(cuid())
  userId          String
  status          String   @default("initialized") // initialized, awaiting_input, processing, executing, completed, failed, cancelled
  currentStepOrder Int     @default(0)
  workflowType    String?
  context         Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  completedAt     DateTime?
  steps           WorkflowStep[]

  @@map("workflow_sessions")
}

model WorkflowStep {
  id                String   @id @default(cuid())
  sessionId         String
  session           WorkflowSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type              String   // ai_question, user_response, backend_execution, result_display, error_handling
  order             Int
  content           String?
  aiPrompt          String?
  userResponse      String?
  functionToExecute String?
  functionParameters Json?
  executionResult   Json?
  error             String?
  timestamp         DateTime @default(now())
  completed         Boolean  @default(false)

  @@map("workflow_steps")
}

model BackendFunction {
  id             String   @id @default(cuid())
  name           String   @unique
  description    String
  category       String
  parameters     Json     @default("[]")
  implementation String
  requiresAuth   Boolean  @default(true)
  dangerous      Boolean  @default(false)
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("backend_functions")
}

model ScheduledWorkflow {
  id              String   @id @default(cuid())
  userId          String
  name            String
  description     String?
  initialRequest  String
  scheduledFor    DateTime
  interval        String?  // cron expression or interval (e.g., "0 9 * * *" for daily at 9am, "1h" for hourly)
  status          String   @default("pending") // pending, running, completed, failed, cancelled
  lastRunAt       DateTime?
  nextRunAt       DateTime?
  runCount        Int      @default(0)
  context         Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("scheduled_workflows")
}

// ShadowGrok-specific models for autonomous C2 operations

model ShadowGrokExecution {
  id              String   @id @default(cuid())
  conversationId  String?
  userId          String
  userMessage     String
  finalResponse   String
  model           String
  toolExecutions  Int      @default(0)
  successfulExecutions Int   @default(0)
  failedExecutions Int     @default(0)
  approvalRequired Boolean @default(false)
  status          String   @default("completed") // completed, failed, pending_approval, cancelled
  error           String?
  executionTimeMs Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  toolCalls       ShadowGrokToolCall[]

  @@map("shadowgrok_executions")
}

model ShadowGrokToolCall {
  id              String   @id @default(cuid())
  executionId     String
  execution       ShadowGrokExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  toolName        String
  arguments       Json
  result          Json?
  success         Boolean
  requiresApproval Boolean @default(false)
  approvalGranted Boolean?
  approvedBy      String?
  approvedAt      DateTime?
  executionTimeMs Int?
  error           String?
  executedAt      DateTime @default(now())

  @@map("shadowgrok_tool_calls")
}

model ShadowGrokApproval {
  id              String   @id @default(cuid())
  toolCallId      String
  toolName        String
  arguments       Json
  requestedBy     String
  requestedAt     DateTime @default(now())
  approvedBy      String?
  approvedAt      DateTime?
  rejectedBy      String?
  rejectedAt      DateTime?
  reason          String?
  status          String   @default("pending") // pending, approved, rejected, expired
  expiresAt       DateTime?

  @@map("shadowgrok_approvals")
}