# --- PostgreSQL / Prisma ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hysteria2?schema=public

# --- Supabase (optional — for Realtime node updates on dashboard) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# --- Hysteria 2 Traffic Stats API ---
HYSTERIA_TRAFFIC_API_BASE_URL=http://127.0.0.1:25000
HYSTERIA_TRAFFIC_API_SECRET=

# --- Hysteria egress (for agent outbound HTTP) ---
HYSTERIA_EGRESS_PROXY_URL=socks5://127.0.0.1:1080

# --- LLM provider (any OpenAI-compatible) ---
LLM_PROVIDER_BASE_URL=https://api.blackbox.ai/api/chat
LLM_PROVIDER_API_KEY=
LLM_MODEL=blackboxai/openai/gpt-4o

# --- ShadowGrok (xAI Grok) Configuration ---
# Enable ShadowGrok autonomous C2 operations
SHADOWGROK_ENABLED=false

# xAI Grok API Configuration
XAI_API_KEY=your-xai-grok-api-key
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.20-reasoning

# ShadowGrok Safety Settings
SHADOWGROK_REQUIRE_APPROVAL=true
SHADOWGROK_MAX_TOOL_ROUNDS=15
SHADOWGROK_MAX_CONCURRENT_TOOLS=5
SHADOWGROK_EXECUTION_TIMEOUT_MS=300000

# ShadowGrok Risk Assessment
SHADOWGROK_RISK_THRESHOLD=70
SHADOWGROK_AUTO_APPROVE_LOW_RISK=true

# --- Redis (optional - for rate limiting and caching) ---
REDIS_URL=redis://localhost:6379

# --- OSINT & Threat Intelligence API Keys ---
# VirusTotal API v3
VIRUSTOTAL_API_KEY=your-virustotal-api-key

# AlienVault OTX API
ALIENVAULT_OTX_KEY=your-alienvault-otx-api-key

# Abuse.ch feeds (no API key required, but you can add for future use)
# ABUSECH_API_KEY= (currently not required)

# Additional OSINT APIs (optional)
# Hunter.io for email harvesting
HUNTER_API_KEY=your-hunter-io-api-key

# Shodan API for network mapping
SHODAN_API_KEY=your-shodan-api-key

# Censys API for network mapping
CENSYS_API_ID=your-censys-api-id
CENSYS_API_SECRET=your-censys-api-secret

# --- Admin Setup ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# --- AI & Autonomous Systems ---
# Enable/disable individual AI systems
ENABLE_AI_SCHEDULING=true
ENABLE_AI_OPTIMIZATION=true
ENABLE_AI_PREDICTIVE_CACHE=true
ENABLE_AI_THREAT_CORRELATION=true
ENABLE_AI_ANOMALY_DETECTION=true

# Auto-initialize AI systems on startup
AUTO_INIT_AI=true

# AI optimization interval (milliseconds)
AI_OPTIMIZATION_INTERVAL=300000